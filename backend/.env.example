# BoardWay 백엔드 환경변수 예시
# 이 파일을 복사해서 .env 로 저장하고 실제 값으로 채우세요

# 필수: JWT 서명용 비밀키 (미설정 시 서버 부팅 실패)
# 생성법: openssl rand -hex 32
SECRET_KEY=change-this-in-production

# DB 연결 URL (없으면 SQLite 사용)
# Railway 배포 시: Railway 대시보드에서 PostgreSQL 추가하면 자동 제공
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# CORS 허용 도메인 (배포 후 프론트엔드 URL 입력, 쉼표 구분)
# CORS_ORIGINS=https://your-app.vercel.app
